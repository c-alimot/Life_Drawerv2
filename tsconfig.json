{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@store": ["./src/store"],
      "@store/*": ["./src/store/*"],
      "@services": ["./src/services"],
      "@services/*": ["./src/services/*"],
      "@types": ["./src/types"],
      "@types/*": ["./src/types/*"],
      "@components": ["./src/components"],
      "@components/*": ["./src/components/*"],
      "@features": ["./src/features"],
      "@features/*": ["./src/features/*"],
      "@constants": ["./src/constants"],
      "@constants/*": ["./src/constants/*"],
      "@hooks": ["./src/hooks"],
      "@hooks/*": ["./src/hooks/*"],
      "@utils": ["./src/utils"],
      "@utils/*": ["./src/utils/*"],
      "@styles": ["./src/styles"],
      "@styles/*": ["./src/styles/*"],
      "@navigation": ["./src/navigation"],
      "@navigation/*": ["./src/navigation/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
